// Code your design here
module dec4_1(D, A, B);
  input A, B;
  output [3:0] D;

  assign D[0] = ~A & ~B;
  assign D[1] = ~A &  B;
  assign D[2] =  A & ~B;
  assign D[3] =  A &  B;

endmodule

