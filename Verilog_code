module tb;
  reg A, B;
  wire [3:0] D;

  dec4_1 dut(D, A, B);

  initial begin
    A=0; B=0; #5;
    A=0; B=1; #5;
    A=1; B=0; #5;
    A=1; B=1; #5;

    #10 $finish;
  end

  always @(A, B)
    $display("A=%b B=%b  Decoder Output = %b", A, B, D);

  initial begin
    $dumpfile("dump.vcd");
    $dumpvars();
  end
endmodule
